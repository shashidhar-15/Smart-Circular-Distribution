// word-wrap into lines that fit SCREEN_WIDTH for current text size void wrapTextToLines(const String &text, vector<String> &outLines) { outLines.clear();
String trimmed = text; trimmed.trim();
// replace CR/LF with spaces trimmed.replace("\r", " ");
trimmed.replace("\n", " ");
// split words by spaces int len = trimmed.length(); int i = 0;
String word = ""; vector<String> words; while (i < len) { char c = trimmed[i]; if (c == ’ ’) {
if (word.length() > 0) { words.push_back(word); word = "";
 
}
// preserve single space as separator
} else { word += c;
} i++;
}
if (word.length() > 0) words.push_back(word); String line = "";
for (size_t widx = 0; widx < words.size(); ++widx) { String &wrd = words[widx];
// candidate if we add this word to current line
String candidate = (line.length() == 0) ? wrd : (line + " " + wrd);
// measure candidate width int16_t x1, y1;
uint16_t candW, candH;
display.getTextBounds(candidate.c_str(), 0, 0, &x1, &y1, &candW, &candH);
// if too wide and line empty -> break the word itself into pieces if (candW > SCREEN_WIDTH && line.length() == 0) {
// break the word into character chunks that fit String part = "";
for (int ci = 0; ci < wrd.length(); ++ci) { part += wrd[ci];
display.getTextBounds(part.c_str(), 0, 0, &x1, &y1, &candW, &candH); if (candW > SCREEN_WIDTH) {
// remove last char part.remove(part.length() - 1); outLines.push_back(part);
part = String(wrd[ci]); // start new part with current char
} }
if (part.length() > 0) outLines.push_back(part); line = ""; // start new line after word parts
} else if (candW <= SCREEN_WIDTH) {
// ok to add line = candidate;
} else {
 
// candidate too wide, push current line and start new line with word if (line.length() > 0) outLines.push_back(line);
line = wrd;
}
}
if (line.length() > 0) outLines.push_back(line);
}
