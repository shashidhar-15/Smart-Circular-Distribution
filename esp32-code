// compute lineHeight using getTextBounds of "Tg" as approximate height int16_t x1, y1;
uint16_t w, h;
display.getTextBounds("Tg", 0, 0, &x1, &y1, &w, &h); lineHeight = max(8, (int)h); // ensure at least 8 areaY = headerHeight;
areaHeight = SCREEN_HEIGHT - headerHeight; blockHeight = (int)wrappedLines.size() * lineHeight; Serial.println("----- layoutMessageBlock	");
