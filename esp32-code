if (blockHeight <= areaHeight) { verticalScrolling = false; scrollY = 0;
// draw static immediately drawStaticBlock();
Serial.println("verticalScrolling = false (fits)");
} else { verticalScrolling = true;
scrollY = 0; // start at top (0). We’ll scroll negative.
 
