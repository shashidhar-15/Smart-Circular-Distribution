drawStaticBlock(); // draws header and first visible part Serial.println("verticalScrolling = true (will scroll)");
} }
// draw header + static block at current scrollY (if scrollY==0 it draws top) void drawStaticBlock() {
display.clearDisplay();
// header (draw slightly lower inside the header band) display.setTextSize(1); display.setTextColor(SSD1306_WHITE); display.setCursor(0, headerTextY); display.print("From: ");
display.println(senderName);
// message area
int y = areaY + scrollY; // initial y offset display.setTextSize(1);
for (size_t i = 0; i < wrappedLines.size(); ++i) { if (y + lineHeight < areaY) {
// line is above visible area; skip y += lineHeight;
continue;
}
if (y >= SCREEN_HEIGHT) {
// below visible area; then break break;
}
display.setCursor(0, y); display.print(wrappedLines[i]); y += lineHeight;
}
display.display();
}
// redraw during scrolling (uses current scrollY) void redrawMessageBlock() {
 
// keep header intact, clear only message area
display.fillRect(0, areaY, SCREEN_WIDTH, areaHeight, SSD1306_BLACK); int y = areaY + scrollY;
for (size_t i = 0; i < wrappedLines.size(); ++i) { if (y + lineHeight < areaY) {
y += lineHeight; continue;
}
if (y >= SCREEN_HEIGHT) break; display.setCursor(0, y); display.print(wrappedLines[i]); y += lineHeight;
}
display.display();
}
